# WSL 2 configuration file
# This file should be placed in your Windows user directory (C:\Users\<YourUsername>\.wslconfig)
# Copy this file to: %USERPROFILE%\.wslconfig

[wsl2]
# Limits VM memory to use no more than 20GB (allows for full container limits + overhead)
# memory= 20GB

# Specify a custom Linux kernel to use with your installed distros. The default kernel used can be found at https://github.com/microsoft/WSL2-Linux-Kernel
# kernel=C:\\temp\\myCustomKernel

# Sets additional kernel parameters, in this case enabling nested virtualization
# kernelCommandLine = vsyscall=emulate

# Sets amount of swap space to 2GB for better performance
swap=2GB

# Sets swapfile path location, default is %USERPROFILE%\AppData\Local\Temp\swap.vhdx
# swapfile=C:\\temp\\wsl-swap.vhdx

# Enable page reporting so WSL releases memory back to Windows when free
pageReporting=true

# Enable memory reclaim to return unused memory to Windows
vmIdleTimeout=60000

# Turn on default connection to bind WSL 2 localhost to Windows localhost
localhostforwarding=true

# Disables nested virtualization
# nestedVirtualization=false

# Turns on output console showing contents of dmesg when opening a WSL 2 distro for debugging
# debugConsole=true
