        </mxCell>
        <mxCell id="p6_dom_parse" value="domain/_parsing.py&#10;_safe_float · _parse_car_coordinates  (small helpers — can also stay inline in telemetry.py)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#5d3b6f;strokeWidth=4;fontSize=10;align=left;verticalAlign=middle;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="510" width="1080" height="40" as="geometry" />
        </mxCell>
        <mxCell id="p6_dom_note" value="Domain is a LEAF. After moving expert/tire-grip feature catalogs out of services/ (see Page 5), segment_models.py can drop its service-imports and land here cleanly." style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fontStyle=2;fontColor=#8a4a00;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="555" width="1080" height="40" as="geometry" />
        </mxCell>

        <mxCell id="p6_band_ml" value="app/ml/online/   —   online-learning algorithm registry (River wrappers)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;fontColor=#7f6000;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="540" y="610" width="1120" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p6_ml_reg" value="ml/online/algorithm_registry.py&#10;AlgorithmConfiguration  —  prediction-task → River-algorithm lookup. Sibling to ml/transformer/, ml/imitation/, ml/segment_classifier/." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b35900;strokeWidth=4;fontSize=10;align=left;verticalAlign=middle;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="640" width="1080" height="40" as="geometry" />
        </mxCell>

        <mxCell id="p6_warning" value="⚠ Order of operations:   the feature-catalog moves on Page 5 (ExpertFeatureCatalog · TireGripFeatureCatalog → app/domain/) must happen BEFORE segment_models.py can move.&#10;Today segment_models.py imports those catalogs from services/, which crosses layers. Move the catalogs first → segment_models.py's imports become legal → then ship it to domain/." style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#7a2e2c;fillColor=#fdebec;strokeColor=#7a2e2c;rounded=1;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="710" width="1620" height="80" as="geometry" />
        </mxCell>

        <mxCell id="p6_summary" value="Net effect of the models/ split:   1 file (api_models) splits into 2 destinations · 1 file (segment_models) splits into 2 destinations · 1 file (telemetry_models) → 1 destination · 1 file (ml_algorithms) → 1 destination.&#10;app/models/ ends up empty and is deleted. Nothing called &quot;model&quot; survives — each file lands in a band named after what it actually IS." style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#23445d;fillColor=#f5f5f5;strokeColor=#23445d;rounded=1;spacingLeft=12;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="800" width="1620" height="80" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

