        </mxCell>
        <mxCell id="p6_dom_tel" value="domain/telemetry.py&#10;TelemetryFeatures pydantic model (the canonical ACC telemetry shape)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#5d3b6f;strokeWidth=4;fontSize=10;align=left;verticalAlign=middle;spacingLeft=10;" vertex="1" parent="1">
