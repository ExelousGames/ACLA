        <mxCell id="p6_lg_t" value="telemetry_models.py  (~53 KB)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#5d3b6f;strokeWidth=4;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="1230" y="125" width="430" height="28" as="geometry" />
