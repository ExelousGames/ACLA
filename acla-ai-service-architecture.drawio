          <mxGeometry x="560" y="410" width="540" height="40" as="geometry" />
        </mxCell>
        <mxCell id="p6_dom_labels" value="domain/labels.py&#10;LABEL_MAPPING dict (O · MD · EA · PS · RM · MS · …)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2d5e2d;strokeWidth=4;fontSize=10;align=left;verticalAlign=middle;spacingLeft=10;" vertex="1" parent="1">
