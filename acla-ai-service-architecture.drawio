                <mxCell id="p5_lg_s" value="segment_classifier_service.py  (996)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#5d3b6f;strokeWidth=4;fontSize=11;align=center;" parent="1" vertex="1">
                    <mxGeometry x="690" y="125" width="290" height="28" as="geometry"/>
                </mxCell>
                <mxCell id="p5_lg_tg" value="tire_grip_analysis_service.py  (186)  ★ NOT ML" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b35900;strokeWidth=4;fontSize=11;align=center;" parent="1" vertex="1">
