            </root>
        </mxGraphModel>
    </diagram>
    <diagram name="4. Migration &amp; Principles" id="page4">
        <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="1500" pageHeight="1100" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="p4_title" value="Page 4 — Migration Plan &amp; Architecture Principles" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fillColor=#23445d;strokeColor=#23445d;fontColor=#ffffff;" parent="1" vertex="1">
                    <mxGeometry x="40" y="20" width="1420" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="p4_nav" value="Pages:  ① Overview  ·  ② Agent &amp; Domain  ·  ③ Providers, Storage &amp; External  ·  ④ Migration &amp; Principles  ·  ⑤ Services Split  ·  ⑥ models/ Split" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#666666;" parent="1" vertex="1">
                    <mxGeometry x="40" y="60" width="1420" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="p4_oss_h" value="Open-Source Inspirations" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;fillColor=#23445d;fontColor=#ffffff;" parent="1" vertex="1">
                    <mxGeometry x="40" y="100" width="700" height="32" as="geometry"/>
                </mxCell>
                <mxCell id="p4_oss_hex" value="Hexagonal (Ports &amp; Adapters)&#xa;Domain in the center; inbound and outbound adapters at the edges. Pipelines = inbound ports. Providers / storage = outbound. External systems sit OUTSIDE the hexagon." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#23445d;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="40" y="140" width="340" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="p4_oss_langgraph" value="LangGraph (already used)&#xa;planner → executor → synthesizer → evaluator state machine. Keep — move it under app/agents/framework.py." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#23445d;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="400" y="140" width="340" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="p4_oss_pipecat" value="Pipecat&#xa;Reference voice pipeline. Already wired in voice/pipecat_pipeline.py. Wrap as VoiceSession use-case." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#23445d;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="40" y="260" width="340" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="p4_oss_vercel" value="Vercel AI SDK / OpenAI client&#xa;Unified LLM interface under app/llm/ with swappable providers — llama / claude / future. AsyncOpenAI already abstracts this; formalize." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#23445d;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="400" y="260" width="340" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="p4_oss_claudesdk" value="Anthropic claude-agent-sdk&#xa;Subagents + tool registration model is the reference for the agent box. Already used by the Claude runner." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#23445d;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="40" y="370" width="340" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="p4_oss_modmono" value="Modular monolith (Backstage)&#xa;One deployable, but strict package boundaries enforced by import rules — no service may import a peer in a lower band." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#23445d;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="400" y="370" width="340" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="p4_rules_h" value="Layering Rules (enforce with import-linter)" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;fillColor=#23445d;fontColor=#ffffff;" parent="1" vertex="1">
                    <mxGeometry x="40" y="490" width="700" height="32" as="geometry"/>
                </mxCell>
                <mxCell id="p4_rules" value="1.  Imports flow downward only:&#xa;     api → pipelines → agents → ml → llm/voice/integrations → storage&#xa;     (domain · features · skills are pure leaves; everyone imports them, they import nothing.)&#xa;&#xa;2.  Domain has zero framework dependencies (no FastAPI, no LangGraph, no anthropic SDK).&#xa;&#xa;3.  Pipelines own orchestration. Agents own LLM capability. Outbound adapters own I/O.&#xa;&#xa;4.  UI never imports a provider directly. It calls a pipeline through the API band.&#xa;&#xa;5.  app/skills/ holds skill DEFINITIONS (yaml = agent instructions / prompts / rules). NOT the same as the feature CATALOGS in app/domain/ (column-name enums for data enrichment). Different words on purpose.&#xa;&#xa;6.  Storage = LOCAL filesystem owned by us. External = network endpoints we don&#39;t own. Never mix.&#xa;&#xa;7.  app/features/ holds STATELESS computation (e.g. tire grip math). No I/O, no state. Not ML.&#xa;&#xa;8.  One source of truth for config: app/infra/config/. Delete app/core/ vs app/config/ duplication." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#23445d;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="40" y="530" width="700" height="320" as="geometry"/>
                </mxCell>
                <mxCell id="p4_pain_h" value="Today&#39;s Pain Points" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;fillColor=#7a2e2c;fontColor=#ffffff;" parent="1" vertex="1">
                    <mxGeometry x="40" y="870" width="700" height="32" as="geometry"/>
                </mxCell>
                <mxCell id="p4_pain" value="× services/ is a junk drawer: ML, LLM, voice, backend HTTP, storage all in one folder.&#xa;× The 5 ML-named files mix model code, dataset loading, training loops, and orchestration in single files — see Page 5.&#xa;× models/ mixes Pydantic DTOs and heavy ML model code (transformer_model.py).&#xa;× core/ and config/ both hold settings — unclear which wins.&#xa;× analyzers/ is empty (vestigial).&#xa;× LLM concerns split across services/llm/agent, services/llm/annotation, services/llm/local_llm at the same depth.&#xa;× UI imports pipelines in-process (Streamlit ↔ app code coupled — only works in the dev container).&#xa;× tire_grip_analysis_service.py is misnamed: it is physics math, not ML." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdebec;strokeColor=#7a2e2c;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="40" y="910" width="700" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="p4_mig_h" value="Migration Map  (today → target)" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;fillColor=#2d5e2d;fontColor=#ffffff;" parent="1" vertex="1">
                    <mxGeometry x="760" y="100" width="700" height="32" as="geometry"/>
                </mxCell>
                <mxCell id="p4_mig" value="services/ai_service.py                    → pipelines/chat/&#xa;services/voice/*                          → voice/&#xa;services/llm/agent/*                      → agents/&#xa;services/llm/annotation/*                 → pipelines/annotation/&#xa;                                            + agents/flows/&#xa;services/llm/local_llm_service.py         → llm/llama_client&#xa;                                            + llm/vlm_local&#xa;services/llm/llama_health.py              → llm/health.py&#xa;services/llm/skill_prompts.py             → skills/prompts.py&#xa;services/llm/label_catalog.py             → domain/labels.py&#xa;services/llm/telemetry_llm_orchestrator   → pipelines/chat/&#xa;services/llm/classifier_prompt_generation → ml/prompts.py&#xa;services/llm/annotation_pipeline.py       → pipelines/annotation/__init__.py&#xa;&#xa;------------------------------------&#xa;See Page 5 for the FIVE ML-named services:&#xa;  transformer_model.py, imitate_expert_learning_service.py,&#xa;  segment_classifier_service.py, tire_grip_analysis_service.py,&#xa;  full_dataset_ml_service.py&#xa;------------------------------------&#xa;&#xa;services/telemetry_segment_visualizer     → pipelines/inference/visualizer.py&#xa;services/segment_updater.py               → pipelines/inference/updater.py&#xa;&#xa;services/zarr_telemetry_store.py          → storage/zarr/&#xa;services/model_cache_service.py           → storage/cache/&#xa;services/backend_service.py               → integrations/backend/&#xa;&#xa;skill_manager/                            → skills/  (code: _registry, _embedder, _query)&#xa;skill_manager/skills/*.yaml               → skills/*.yaml  (skill DEFINITIONS, not &quot;catalog&quot;)&#xa;&#xa;config/cache_config.py                    → infra/config/cache.py&#xa;config/pipeline_config.py                 → infra/config/pipeline.py&#xa;core/config.py                            → infra/config/settings.py&#xa;&#xa;------------------------------------&#xa;See Page 6 for the FOUR files in models/:&#xa;  api_models.py, ml_algorithms.py,&#xa;  segment_models.py, telemetry_models.py&#xa;------------------------------------&#xa;&#xa;analyzers/                                → DELETE (empty)&#xa;ui/                                       → standalone repo (later)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2d5e2d;fontSize=10;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;fontFamily=Courier New;" parent="1" vertex="1">
                    <mxGeometry x="760" y="140" width="700" height="940" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
    <diagram name="5. ML File Split" id="page5">
        <mxGraphModel dx="1024" dy="826" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1300" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="p5_title" value="Page 5 — ML / Service File Split:  5 files in services/  →  domain + features + ml + storage + pipelines" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fillColor=#23445d;strokeColor=#23445d;fontColor=#ffffff;" parent="1" vertex="1">
                    <mxGeometry x="40" y="20" width="1620" height="40" as="geometry"/>
                </mxCell>
