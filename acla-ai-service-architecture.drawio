          <mxGeometry x="430" y="125" width="380" height="28" as="geometry" />
        </mxCell>
        <mxCell id="p6_lg_s" value="segment_models.py  (~11 KB)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2d5e2d;strokeWidth=4;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="830" y="125" width="380" height="28" as="geometry" />
