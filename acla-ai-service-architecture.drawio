        <mxCell id="p6_title" value="Page 6 — models/ Folder Split:  4 files in models/  →  api/schemas + integrations + domain + ml" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fillColor=#23445d;strokeColor=#23445d;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1620" height="40" as="geometry" />
        </mxCell>
        <mxCell id="p6_nav" value="Pages:  ① Overview  ·  ② Agent &amp; Domain  ·  ③ Providers, Storage &amp; External  ·  ④ Migration &amp; Principles  ·  ⑤ Services Split  ·  ⑥ models/ Split" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="1620" height="20" as="geometry" />
        </mxCell>

        <mxCell id="p6_legend" value="The word &quot;model&quot; was overloaded — it meant Pydantic DTOs, ML algorithm registry, and domain types all at once.  Color = source file." style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#23445d;fillColor=#f5f5f5;strokeColor=#23445d;rounded=1;" vertex="1" parent="1">
