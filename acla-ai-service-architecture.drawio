        <mxCell id="p6_src_h" value="TODAY  —  app/models/" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;fillColor=#23445d;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="40" y="170" width="460" height="32" as="geometry" />
        </mxCell>

        <mxCell id="p6_src_a" value="api_models.py  (64 LOC)&#10;&#10;Pure Pydantic HTTP DTOs:&#10;• QueryRequest · AnalysisResult · HealthResponse · DatasetInfo · BackendCallRequest&#10;• AiModelDto · ActiveModelData  (these two are wire formats for the Node backend, not HTTP)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1f6091;strokeWidth=3;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="210" width="460" height="140" as="geometry" />
        </mxCell>
        <mxCell id="p6_src_m" value="ml_algorithms.py  (~24 KB)&#10;&#10;AlgorithmConfiguration class — a registry / lookup table mapping prediction task names → River algorithm choices.&#10;Imports the `river` online-learning library.&#10;&#10;It is a CONFIG file, not actual model code. No fit / predict implementations." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b35900;strokeWidth=3;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="360" width="460" height="140" as="geometry" />
        </mxCell>
        <mxCell id="p6_src_s" value="segment_models.py  (~11 KB)&#10;&#10;Domain dataclasses + the master LABEL_MAPPING dict (~150 entries: O, MD, EA, PS, RM, MS, RM1–RM11, MS1–MS52, …).&#10;&#10;⚠  IMPORTS FROM services/ — domain code importing service code violates the layering rule. Must be reversed before this file can move cleanly to domain/." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2d5e2d;strokeWidth=3;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="510" width="460" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p6_src_t" value="telemetry_models.py  (~53 KB — the biggest file)&#10;&#10;TelemetryFeatures Pydantic model — the canonical ACC telemetry shape.&#10;+ safe-parsing helpers: _safe_float, _parse_car_coordinates&#10;&#10;Pure domain type. No I/O, no framework, no ML." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#5d3b6f;strokeWidth=3;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="690" width="460" height="140" as="geometry" />
        </mxCell>

        <mxCell id="p6_tgt_h" value="TARGET  —  app/" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;fillColor=#2d5e2d;fontColor=#ffffff;" vertex="1" parent="1">
