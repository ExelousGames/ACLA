    <diagram name="2. Agent &amp; Domain" id="page2">
        <mxGraphModel dx="1024" dy="826" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="1100" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="p2_title" value="Page 2 — Agent Capability Box · Domain · Features" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fillColor=#23445d;strokeColor=#23445d;fontColor=#ffffff;" parent="1" vertex="1">
                    <mxGeometry x="40" y="20" width="1420" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="p2_nav" value="Pages:  ① Overview  ·  ② Agent &amp; Domain  ·  ③ Providers, Storage &amp; External  ·  ④ Migration &amp; Principles  ·  ⑤ Services Split  ·  ⑥ models/ Split" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#666666;" parent="1" vertex="1">
                    <mxGeometry x="40" y="60" width="1420" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="p2_callers" value="↑ Callers (from Page 1):  AnnotationPipeline   ·   ChatService   ·   VoiceSession   ·   InferencePipeline" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontColor=#2d5e2d;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="40" y="100" width="1420" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="p2_band_agent" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;verticalAlign=top;align=left;" parent="1" vertex="1">
                    <mxGeometry x="40" y="170" width="1420" height="420" as="geometry"/>
                </mxCell>
                <mxCell id="p2_agent_lbl" value="AGENT CAPABILITY BOX&#xa;app/agents/&#xa;&#xa;Domain-free.&#xa;Accepts AgentRequest,&#xa;returns AgentResponse." style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#5d3b6f;" parent="1" vertex="1">
                    <mxGeometry x="60" y="220" width="180" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="p2_framework" value="FRAMEWORK  (LangGraph)&#xa;app/agents/framework.py&#xa;&#xa;planner ──► executor ──► synthesizer ──► evaluator&#xa;&#xa;• AttachmentPool (state passing between nodes)&#xa;• AgentBudget (recursion cap)&#xa;• Cycle detection on (name, parent_start, parent_end)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#5d3b6f;fontSize=11;fontStyle=1;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="270" y="200" width="540" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="p2_runners" value="RUNNERS&#xa;app/agents/runners/&#xa;&#xa;• local.py — local VLM (llama-server)&#xa;• claude.py — claude-agent-sdk subprocess" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#5d3b6f;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="840" y="200" width="290" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="p2_subs" value="SUB-AGENTS&#xa;app/agents/sub_agents/&#xa;&#xa;• describe_graphs.py — VLM observation pass&#xa;• label_verifier.py — score observations vs catalog&#xa;• zoom.py — drill into sub-ranges" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#5d3b6f;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="1160" y="200" width="290" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="p2_tools" value="TOOL REGISTRY  app/agents/tools/&#xa;&#xa;split_lap_by_sections · list_eligible_labels · render_graph&#xa;predict_telemetry · query_backend · classify_segment · …&#xa;&#xa;Tools are pure functions the runner exposes to the LLM (function calling /  claude-sdk MCP)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#5d3b6f;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="270" y="370" width="540" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="p2_flows" value="FLOWS  app/agents/flows/&#xa;&#xa;build_request(domain context)  →  AgentRequest&#xa;parse(AgentResponse, domain context)  →  typed result&#xa;&#xa;• annotation/detailed.py  · annotation/lap.py · chat/* · contracts.py" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4ecf7;strokeColor=#9673a6;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontStyle=2;" parent="1" vertex="1">
                    <mxGeometry x="840" y="370" width="610" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="p2_contract" value="contracts.py:   AgentRequest  ·  AgentResponse  ·  Attachment  ·  AgentCallbacks  ·  BackendConfig&#xa;Boundary contract — domain stays OUT of the agent box. Callers pre-build prompts and attachments; runners ferry them to providers." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#5d3b6f;fontSize=11;align=center;fontStyle=2;" parent="1" vertex="1">
                    <mxGeometry x="270" y="510" width="1180" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="p2_band_domain" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;verticalAlign=top;align=left;" parent="1" vertex="1">
                    <mxGeometry x="40" y="620" width="1420" height="350" as="geometry"/>
                </mxCell>
                <mxCell id="p2_domain_lbl" value="DOMAIN&#xa;FEATURES&#xa;&amp; SKILLS&#xa;&#xa;app/domain/&#xa;app/features/&#xa;app/skills/" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#8a4a00;" parent="1" vertex="1">
                    <mxGeometry x="60" y="710" width="180" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="p2_d_types" value="Domain Types  app/domain/&#xa;&#xa;Telemetry · Segment · Lap · Label&#xa;Session · Circuit · CarSetup&#xa;&#xa;+ feature catalogs:&#xa;ExpertFeatureCatalog · TireGripFeatureCatalog&#xa;SegmentImprovementConfig · …" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#8a4a00;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="270" y="650" width="370" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="p2_d_features" value="Feature Library  app/features/  (NEW)&#xa;&#xa;Stateless feature engineering — no I/O, no model state.&#xa;&#xa;• tire_grip.py — friction-circle calc (was tire_grip_analysis_service)&#xa;• derived.py — derived telemetry features used by classifiers&#xa;&#xa;Used by both training and inference pipelines. Not ML." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#8a4a00;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="660" y="650" width="380" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="p2_d_skills" value="Skill Registry  app/skills/&#xa;&#xa;• _registry.py — load yaml, build index&#xa;• _embedder.py — sentence-transformers&#xa;• _query.py — search / find / iter / get&#xa;&#xa;Lazy proxy: skills.get(path), skills.search(q)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#8a4a00;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="1060" y="650" width="380" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="p2_d_catalog" value="Skill Definitions  app/skills/&lt;name&gt;.yaml  —  tells the agent HOW to do something&#xa;&#xa;• lap_annotation.yaml — main-label rules &amp; instructions (cross-circuit)&#xa;• sub_label_catalog.yaml — sub-label descriptions used by the verifier sub-agent&#xa;• graph_analysis.yaml — VLM image-analysis prompts&#xa;&#xa;⚠  Not the same as &quot;feature catalogs&quot; in app/domain/ (left). Those enumerate feature NAMES for data enrichment.&#xa;     A skill = agent instructions / prompts / rules.   A feature catalog = lookup of column names.&#xa;Drop a yaml file in, restart, skill is available." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e8;strokeColor=#8a4a00;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="270" y="810" width="1170" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="p2_next" value="↓  Runners hand prompts &amp; images to Provider Adapters (LLM/VLM)  —  see Page 3  ↓" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;fontColor=#7a2e2c;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="40" y="1000" width="1420" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="p2_legend" value="Three different things — DON&#39;T confuse them:&#xa;     • Domain TYPES — pydantic / dataclass definitions including feature catalogs (lists of column names).&#xa;     • FEATURES — stateless math (e.g. friction-circle) that enriches raw data with derived columns.&#xa;     • SKILL DEFINITIONS — yaml that tells the AGENT how to behave (prompts, rules, label descriptions).&#xa;None of these import a framework or talk to a network. Pipelines, agents, and ML models all consume from here — never the reverse." style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#8a4a00;fillColor=#fff8e8;strokeColor=#d79b00;rounded=1;spacingLeft=12;" parent="1" vertex="1">
                    <mxGeometry x="40" y="1050" width="1420" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="p2_e1" style="endArrow=classic;html=1;rounded=0;strokeColor=#5d3b6f;strokeWidth=2;" parent="1" source="p2_framework" target="p2_runners" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p2_e2" style="endArrow=classic;html=1;rounded=0;strokeColor=#5d3b6f;strokeWidth=1;" parent="1" source="p2_framework" target="p2_subs" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p2_e3" style="endArrow=classic;html=1;rounded=0;strokeColor=#5d3b6f;strokeWidth=1;" parent="1" source="p2_framework" target="p2_tools" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p2_e4" style="endArrow=classic;html=1;rounded=0;strokeColor=#5d3b6f;strokeWidth=1;" parent="1" source="p2_subs" target="p2_tools" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p2_e5" style="endArrow=classic;html=1;rounded=0;strokeColor=#5d3b6f;strokeWidth=1;dashed=1;" parent="1" source="p2_subs" target="p2_d_skills" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p2_e6" style="endArrow=classic;html=1;rounded=0;strokeColor=#5d3b6f;strokeWidth=1;dashed=1;" parent="1" source="p2_tools" target="p2_d_catalog" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p2_e7" style="endArrow=classic;html=1;rounded=0;strokeColor=#8a4a00;strokeWidth=1;" parent="1" source="p2_d_skills" target="p2_d_catalog" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
    <diagram name="3. Providers, Storage &amp; External" id="page3">
        <mxGraphModel dx="1024" dy="826" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="1000" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="p3_title" value="Page 3 — Outbound Adapters · Local Storage · External Services" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fillColor=#23445d;strokeColor=#23445d;fontColor=#ffffff;" parent="1" vertex="1">
                    <mxGeometry x="40" y="20" width="1420" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="p3_nav" value="Pages:  ① Overview  ·  ② Agent &amp; Domain  ·  ③ Providers, Storage &amp; External  ·  ④ Migration &amp; Principles  ·  ⑤ Services Split  ·  ⑥ models/ Split" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#666666;" parent="1" vertex="1">
                    <mxGeometry x="40" y="60" width="1420" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="p3_callers" value="↑ Callers:  Agent Runners (Page 2)   ·   VoiceSession (Page 1)   ·   TrainingPipeline (Page 1)   ·   ChatService (Page 1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontColor=#5d3b6f;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="40" y="100" width="1420" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="p3_band_prov" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;verticalAlign=top;align=left;" parent="1" vertex="1">
                    <mxGeometry x="40" y="170" width="1420" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="p3_prov_lbl" value="OUTBOUND ADAPTERS&#xa;app/llm/  ·  app/voice/&#xa;app/ml/  ·  app/integrations/&#xa;&#xa;In-app code that owns I/O&#xa;to providers and integrations." style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#7a2e2c;" parent="1" vertex="1">
                    <mxGeometry x="60" y="230" width="180" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="p3_llm" value="LLM Clients&#xa;app/llm/&#xa;&#xa;llama_client&#xa;(OpenAI-compat)&#xa;&#xa;claude_client&#xa;(Anthropic SDK)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#7a2e2c;fontSize=11;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="270" y="200" width="200" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="p3_vlm" value="VLM&#xa;app/llm/vlm_local&#xa;&#xa;Qwen2.5-VL&#xa;+ mmproj projector" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#7a2e2c;fontSize=11;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="490" y="200" width="170" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="p3_stt" value="STT&#xa;app/voice/stt/&#xa;&#xa;faster-whisper" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#7a2e2c;fontSize=11;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="680" y="200" width="130" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="p3_tts" value="TTS&#xa;app/voice/tts/&#xa;&#xa;Kokoro-ONNX" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#7a2e2c;fontSize=11;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="830" y="200" width="130" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="p3_pipecat" value="Voice Pipeline&#xa;app/voice/pipeline.py&#xa;&#xa;Pipecat factory:&#xa;VAD ▸ STT ▸ LLM ▸ TTS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#7a2e2c;fontSize=11;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="980" y="200" width="180" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="p3_ml" value="ML Model Code&#xa;app/ml/&#xa;&#xa;transformer/ · imitation/&#xa;segment_classifier/&#xa;(see Page 5)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#7a2e2c;fontSize=11;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="1180" y="200" width="200" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="p3_backend" value="Backend HTTP Adapter&#xa;app/integrations/backend/&#xa;&#xa;JWT auth · retry · timeout&#xa;Calls Node service" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#7a2e2c;fontSize=11;align=center;verticalAlign=middle;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="270" y="370" width="280" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="p3_prov_note" value="Rule of thumb:&#xa;everything in this band is IN our app but reaches OUTSIDE.&#xa;Timeouts, retries, auth, error mapping live here — never in pipelines." style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontStyle=2;fontColor=#7a2e2c;" parent="1" vertex="1">
                    <mxGeometry x="570" y="370" width="810" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="p3_band_storage" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#666666;verticalAlign=top;align=left;" parent="1" vertex="1">
                    <mxGeometry x="40" y="480" width="1420" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="p3_storage_lbl" value="STORAGE&#xa;app/storage/&#xa;&#xa;Local FS owned by us.&#xa;No network." style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#333333;" parent="1" vertex="1">
                    <mxGeometry x="60" y="520" width="180" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="p3_zarr" value="Zarr Telemetry Store&#xa;app/storage/zarr/&#xa;&#xa;Chunked + compressed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;fontSize=11;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="270" y="510" width="220" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="p3_datasets" value="Datasets&#xa;app/storage/datasets/&#xa;&#xa;TelemetryActionDataset&#xa;StreamingSegmentDataset&#xa;(PyTorch IterableDatasets)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;fontSize=11;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="510" y="510" width="240" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="p3_checkpoints" value="Model Cache + Checkpoints&#xa;app/storage/cache/&#xa;app/storage/checkpoints/&#xa;&#xa;Trained model + scaler I/O" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;fontSize=11;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="770" y="510" width="260" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="p3_ggufvol" value="GGUF / Kokoro Volumes&#xa;docker volume mounts&#xa;&#xa;Downloaded weights only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;fontSize=11;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="1050" y="510" width="240" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="p3_storage_note" value="4 purposes:&#xa;raw data · loaders · cache · weights" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fontStyle=2;fontColor=#333333;" parent="1" vertex="1">
                    <mxGeometry x="1310" y="510" width="140" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="p3_band_ext" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f4cccc;strokeColor=#7a2e2c;verticalAlign=top;align=left;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="670" width="1420" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="p3_ext_lbl" value="EXTERNAL&#xa;SERVICES&#xa;&#xa;Out-of-process.&#xa;Untrusted boundary.&#xa;Not our source code." style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#7a2e2c;" parent="1" vertex="1">
                    <mxGeometry x="60" y="710" width="180" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="p3_ext_llama" value="llama-server sidecar&#xa;localhost:8080&#xa;&#xa;GGUF: Qwen2.5-VL&#xa;(separate process,&#xa;same container)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#7a2e2c;fontSize=11;align=center;verticalAlign=middle;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="270" y="700" width="240" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="p3_ext_backend" value="acla_backend (Node, :7001)&#xa;&#xa;↓&#xa;&#xa;MongoDB (:27017)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#7a2e2c;fontSize=11;align=center;verticalAlign=middle;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="530" y="700" width="280" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="p3_ext_anthropic" value="api.anthropic.com&#xa;&#xa;Claude API&#xa;via SDK subprocess&#xa;(spawns `claude` CLI)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#7a2e2c;fontSize=11;align=center;verticalAlign=middle;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="830" y="700" width="240" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="p3_ext_note" value="No source code lives in this band.&#xa;Adapters above are the ONLY way in.&#xa;Network errors map to typed exceptions&#xa;at the adapter layer." style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontStyle=2;fontColor=#7a2e2c;" parent="1" vertex="1">
                    <mxGeometry x="1090" y="700" width="290" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="p3_legend" value="TOP band = in-app code (outbound adapters).  MIDDLE band = local disk.  BOTTOM band = network boundary.&#xa;An adapter NEVER short-circuits into storage; storage NEVER reaches the network. Each band has exactly one job." style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#23445d;fillColor=#f5f5f5;strokeColor=#23445d;rounded=1;spacingLeft=12;" parent="1" vertex="1">
                    <mxGeometry x="40" y="870" width="1420" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="p3_e1" style="endArrow=classic;html=1;rounded=0;strokeColor=#7a2e2c;strokeWidth=1;" parent="1" source="p3_pipecat" target="p3_stt" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p3_e2" style="endArrow=classic;html=1;rounded=0;strokeColor=#7a2e2c;strokeWidth=1;" parent="1" source="p3_pipecat" target="p3_llm" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p3_e3" style="endArrow=classic;html=1;rounded=0;strokeColor=#7a2e2c;strokeWidth=1;" parent="1" source="p3_pipecat" target="p3_tts" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p3_e4" style="endArrow=classic;html=1;rounded=0;strokeColor=#666666;strokeWidth=1;" parent="1" source="p3_ml" target="p3_datasets" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p3_e5" style="endArrow=classic;html=1;rounded=0;strokeColor=#666666;strokeWidth=1;" parent="1" source="p3_ml" target="p3_checkpoints" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p3_e_ds_zarr" style="endArrow=classic;html=1;rounded=0;strokeColor=#666666;strokeWidth=1;" parent="1" source="p3_datasets" target="p3_zarr" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p3_e6" style="endArrow=classic;html=1;rounded=0;strokeColor=#666666;strokeWidth=1;dashed=1;" parent="1" source="p3_tts" target="p3_ggufvol" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p3_e7" style="endArrow=classic;html=1;rounded=0;strokeColor=#7a2e2c;strokeWidth=2;" parent="1" source="p3_llm" target="p3_ext_llama" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p3_e8" style="endArrow=classic;html=1;rounded=0;strokeColor=#7a2e2c;strokeWidth=1;" parent="1" source="p3_vlm" target="p3_ext_llama" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p3_e9" style="endArrow=classic;html=1;rounded=0;strokeColor=#7a2e2c;strokeWidth=1;" parent="1" source="p3_llm" target="p3_ext_anthropic" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p3_e10" style="endArrow=classic;html=1;rounded=0;strokeColor=#7a2e2c;strokeWidth=2;" parent="1" source="p3_backend" target="p3_ext_backend" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
