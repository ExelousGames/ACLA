                </mxCell>
                <mxCell id="p5_summary" value="Summary of the split:   1 file × ML model (kept)   ·   1 file × physics features (renamed, demoted from ML)   ·   2 files × dataclasses/enums (moved to domain)   ·   2 files × dataset loaders (moved to storage)   ·   5 files × training orchestrators   ·   2 files × inference orchestrators&#xa;Net effect: 5 monolithic services (6 252 LOC) become ~17 focused files. The full_dataset orchestrator stops module-importing siblings — dependencies become explicit constructor args." style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#23445d;fillColor=#f5f5f5;strokeColor=#23445d;rounded=1;spacingLeft=12;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="40" y="1100" width="1620" height="80" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>

  <diagram name="6. models/ Split" id="page6">
    <mxGraphModel dx="2200" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="950" math="0" shadow="0">
