        </mxCell>
        <mxCell id="p6_int_be" value="integrations/backend/schemas.py&#10;AiModelDto · ActiveModelData  (payloads exchanged with acla_backend, not with our React client)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1f6091;strokeWidth=4;fontSize=10;align=left;verticalAlign=middle;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="325" width="1080" height="40" as="geometry" />
        </mxCell>

        <mxCell id="p6_band_dom" value="app/domain/   —   pure types: dataclasses, pydantic models, label dicts (the leaves; no imports of services)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;fontColor=#8a4a00;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="540" y="380" width="1120" height="220" as="geometry" />
        </mxCell>
