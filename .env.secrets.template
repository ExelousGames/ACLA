# Template for environment secrets
# Copy this file to .env.secrets and fill in your actual values
# DO NOT commit .env.secrets to version control

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Google Cloud Storage (GCS) Configuration for Gemini Batch API
# Bucket name without gs:// prefix (e.g., "my-bucket-name")
GEMINI_BATCH_GCS_BUCKET=your_gcs_bucket_name_here

# GCP Service Account (for GCS access)
# Path to your service account JSON file (inside container: /app/service_src/gcp-service-account.json)
GOOGLE_APPLICATION_CREDENTIALS=/app/service_src/gcp-service-account.json

# Hugging Face Configuration
HF_TOKEN=your_hf_token_here
HF_USERNAME=your_hf_username_here

# Admin account (created at backend startup if it doesn't exist)
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_admin_password

# AI Service account (created at backend startup if it doesn't exist)
AI_SERVICE_USERNAME=your_ai_service_username
AI_SERVICE_PASSWORD=your_ai_service_password
